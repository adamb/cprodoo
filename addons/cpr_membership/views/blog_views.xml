<odoo>
    <!-- Hide the blog cover banner on the blog listing page -->
    <template id="hide_blog_cover" inherit_id="website_blog.blog_post_short" name="Hide Blog Cover">
        <xpath expr="//div[@id='o_wblog_blog_top']" position="attributes">
            <attribute name="style">display:none;</attribute>
        </xpath>
    </template>
</odoo>
